# Real Mailgun credentials
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_BASE_URL=https://api.mailgun.net

# Use https://api.eu.mailgun.net for EU-region domains
# MAILGUN_BASE_URL=https://api.eu.mailgun.net

# Secret that Ghost sends as its "Mailgun API key" — never forwarded to real Mailgun
PROXY_API_KEY=replace-with-a-long-random-string

# Throttle target: total recipients per hour across all sends
TARGET_PER_HOUR=200

# Recipients per queued job chunk (smaller = smoother pacing, more API calls)
CHUNK_SIZE=10

# Redis connection (defaults work with docker-compose)
REDIS_HOST=redis
REDIS_PORT=6379

# Port the proxy listens on
PORT=3000
